# Wiznerd Wallet environment config
# Copy to .env.local and customize for your deployment.
# All VITE_ variables are embedded at build time and visible in the browser bundle.

# URL of the Wiznerd proxy server (CORS bridge to Chia node + price/metadata APIs).
# In production: set this to your deployed proxy URL (e.g. https://proxy.yourdomain.com).
# Users can override this at runtime via Settings → Proxy URL.
VITE_PROXY_URL=http://localhost:3001
