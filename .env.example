# Wiznerd Wallet environment config
# Copy to .env and customize. All VITE_ variables are embedded at build time (visible in browser).

# ─── Chia proxy (CORS bridge to Chia node) ──────────────────────────────────
VITE_PROXY_URL=http://localhost:3001

# ─── Art Studio API server (port 3002) ──────────────────────────────────────
VITE_API_URL=http://localhost:3002

# ─── Supabase (required for Art Studio) ─────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# Frontend Supabase client (for Realtime subscriptions on /create)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── IPFS pinning — set ONE of these ────────────────────────────────────────
# Option 1: Pinata (recommended — free tier available at pinata.cloud)
PINATA_JWT=eyJ...

# Option 2: NFT.storage (legacy — API deprecated for new accounts)
NFT_STORAGE_KEY=

# ─── Optional: Redis for async generation queue ──────────────────────────────
# Requires Redis >= 5. Without this, generation runs synchronously.
REDIS_URL=redis://localhost:6379
